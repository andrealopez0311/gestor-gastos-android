<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏠"
        android:textSize="64sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Crea tu hogar"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Crea un hogar e invita a los miembros de tu familia para gestionar juntos vuestros ingresos y gastos."
        android:textSize="14sp"
        android:textColor="#757575"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etNombreHogar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre del hogar (ej: Casa Andrea)"
        android:padding="16dp"
        android:background="@android:color/white"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnAhoraMas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ahora no"
        android:backgroundTint="#9E9E9E"
        android:textColor="@android:color/white"
        android:padding="16dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnCrearHogar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crear Hogar"
        android:backgroundTint="#1E88E5"
        android:textColor="@android:color/white"
        android:padding="16dp"/>

</LinearLayout>