<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- BARRA SUPERIOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#7B1FA2"
        android:padding="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnVolverFondo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Volver"
            android:backgroundTint="#6A1B9A"
            android:textColor="@android:color/white"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏦 Fondo Periódicos"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

    </LinearLayout>

    <!-- RESUMEN FONDO -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvAcumuladoFondo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 €"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#7B1FA2"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Acumulado"
                        android:textSize="12sp"
                        android:textColor="#757575"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvReservaFondo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 €/mes"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#43A047"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reserva mensual"
                        android:textSize="12sp"
                        android:textColor="#757575"/>

                </LinearLayout>

            </LinearLayout>

            <Button
                android:id="@+id/btnAcumularMes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="+ Acumular reserva del mes"
                android:backgroundTint="#7B1FA2"
                android:textColor="@android:color/white"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- BOTÓN AÑADIR CUOTA -->
    <Button
        android:id="@+id/btnAnadirCuota"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ Añadir cuota irregular"
        android:backgroundTint="#7B1FA2"
        android:textColor="@android:color/white"
        android:padding="16dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="8dp"/>

    <!-- LISTA CUOTAS -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📅 Próximas cuotas pendientes"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginLeft="16dp"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCuotas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"/>

</LinearLayout>