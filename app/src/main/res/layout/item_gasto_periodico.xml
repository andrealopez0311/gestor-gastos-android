<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- FILA SUPERIOR: nombre e importe -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombrePeriodico"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#212121"/>

                <TextView
                    android:id="@+id/tvFrecuencia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#757575"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tvProximoPago"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#757575"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvImportePeriodico"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#7B1FA2"/>

                <TextView
                    android:id="@+id/tvReservaMensual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#7B1FA2"
                    android:gravity="center"/>

            </LinearLayout>

        </LinearLayout>

        <!-- BARRA DE PROGRESO -->
        <ProgressBar
            android:id="@+id/progressPeriodico"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#7B1FA2"
            android:layout_marginBottom="8dp"/>

        <!-- FILA INFERIOR: acumulado y botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvAcumuladoPeriodico"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="#757575"/>

            <TextView
                android:id="@+id/tvAlertaPeriodico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:background="#E53935"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginRight="8dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btnPagarPeriodico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Pagado"
                android:backgroundTint="#43A047"
                android:textColor="@android:color/white"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"/>

            <Button
                android:id="@+id/btnEditarPeriodico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️"
                android:backgroundTint="#1E88E5"
                android:textColor="@android:color/white"
                android:layout_marginLeft="8dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"/>

            <Button
                android:id="@+id/btnEliminarPeriodico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗑"
                android:backgroundTint="#EF5350"
                android:textColor="@android:color/white"
                android:layout_marginLeft="8dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>