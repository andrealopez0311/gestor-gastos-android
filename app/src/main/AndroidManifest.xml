<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="Gestor de Gastos"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GestorGastos"
        tools:targetApi="31">

        <!-- Pantalla de Login - es la primera que se abre -->
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Pantalla de Gastos -->
        <activity
            android:name=".ui.gastos.GastosActivity"
            android:exported="false" />
        <!-- Pantalla de Resumen -->
        <activity
            android:name=".ui.gastos.ResumenActivity"
            android:exported="false" />
        <activity
            android:name=".ui.hogar.HogarActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hogar.CrearHogarActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hogar.IngresosActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hogar.GastosComunesActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hogar.AhorroActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hogar.GastosPeriodicosActivity"
            android:exported="false" />

        <activity
            android:name=".ui.hogar.EgresosActivity"
            android:exported="false" />

        <activity
            android:name=".ui.gastos.AhorroPersonalActivity"
            android:exported="false" />


    </application>

</manifest>